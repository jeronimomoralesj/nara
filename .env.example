# ── Fundación Nara ─────────────────────────────────────────────────
# MongoDB — optional. Without it the app runs in zero-config "demo" mode:
# forms validate and respond, but submissions are not persisted.
MONGODB_URI=
MONGODB_DB=fundacion_nara

# ── Ágape shop ──────────────────────────────────────────────────────
# Password for the /agape/admin dashboard
ADMIN_PASSWORD=choose-a-strong-password

# Random secret used to sign the admin session cookie (any long random string)
# Generate: openssl rand -hex 32
ADMIN_SESSION_SECRET=generate-a-long-random-string

# Canonical site URL (no trailing slash). Used for SEO / sitemaps.
NEXT_PUBLIC_SITE_URL=https://fundacionnara.org
